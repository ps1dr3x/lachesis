[
    {
        "name": "elasticsearch",
        "protocol": "http/s",
        "options": {
            "ports": [9200],
            "method": "GET",
            "path": "/"
        },
        "service": {
            "regex": "\"tagline\"\\s*:\\s*\"You Know, for Search\"",
            "log": true
        },
        "versions": {
            "semver": {
                "regex": "\"number\"\\s*:\\s*\"(?P<version>[0-9]+\\.[0-9]+\\.[0-9]+)\"",
                "ranges": [
                    {
                        "from": "1.0.0",
                        "to": "7.17.99",
                        "description": "Elasticsearch < 8.0 (end of life / potentially outdated)"
                    }
                ]
            }
        }
    }
]
